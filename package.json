{
  "name": "trucknet-ai",
  "version": "1.0.0",
  "packageManager": "npm@10.8.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "apps/backend/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "build:web": "npm --workspace=apps/web run build",
    "build:api": "npm --workspace=apps/backend/api run build",
    "build:ai": "npm --workspace=apps/backend/ai-node-engine run build",
    "build:all": "echo 'Skipping monorepo build - Vercel builds only frontend'",
    "start:api": "npm --workspace=apps/backend/api run start",
    "start:ai": "npm --workspace=apps/backend/ai-node-engine run start",
    "start:web": "npm --workspace=apps/web run start",
    "dev:api": "npm --workspace=apps/backend/api run dev",
    "dev:ai": "npm --workspace=apps/backend/ai-node-engine run dev",
    "dev:web": "npm --workspace=apps/web run dev",
    "postinstall": "npm run build:all"
  },
  "engines": {
    "node": ">=20.0.0 <25.0.0",
    "npm": "10.x"
  }
}