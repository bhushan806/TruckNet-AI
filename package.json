{
  "name": "trucknet-ai",
  "version": "1.0.0",
  "packageManager": "npm@10.8.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "apps/backend/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "build:web": "npm --workspace=apps/web run build",
    "build:api": "cd apps/backend/api && npm install && npm run build",
    "build:ai": "cd apps/backend/ai-node-engine && npm install && npm run build",
    "build:all": "npm run build:api && npm run build:ai",
    "start:api": "cd apps/backend/api && node dist/app.js",
    "start:ai": "cd apps/backend/ai-node-engine && node dist/server.js"
  },
  "engines": {
    "node": ">=20.0.0 <25.0.0",
    "npm": "10.x"
  }
}